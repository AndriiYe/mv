# Copy to pi-web-updater.env on the Raspberry Pi and adjust if needed.

PI_WEB_HOST=0.0.0.0
PI_WEB_PORT=8080
PI_WEB_USERNAME=pi
# Set this before exposing the Pi on your LAN.
# PI_WEB_PASSWORD=change-this-password

CV_PROJECT_DIR=/home/pi/mv
CV_BUILD_DIR=build
CV_TARGET=cv
CV_RUNNER=/home/pi/mv/scripts/run-pi-cv.sh
CV_GIT_REMOTE=origin
# Leave empty to pull the current checked-out branch.
CV_GIT_BRANCH=
CV_CMAKE_GENERATOR=Ninja
CV_CMAKE_BUILD_TYPE=Release

# Default stop/start uses pkill and scripts/run-pi-cv.sh.
# For a systemd-managed tracker, uncomment these:
# CV_TRACKER_SERVICE=cv-tracker.service
# CV_TRACKER_SERVICE_SCOPE=user

# For fully custom process control, use command strings without shell features.
# CV_STOP_CMD=systemctl --user stop cv-tracker.service
# CV_START_CMD=systemctl --user start cv-tracker.service
